# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Or individual components
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=secret
DB_SSL=false

# Server
PORT=3000
NODE_ENV=development

# API Configuration
API_PREFIX=/api
# Comma-separated table names to exclude from API exposure
EXCLUDED_TABLES=schema_migrations,knex_migrations,knex_migrations_lock

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
